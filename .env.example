# ──────────────────────────────────────────────
# PulsarTeam — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# Server
JWT_SECRET=change-me-to-a-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=swarm2026

# At-rest encryption key for stored credentials/tokens (required by the api
# and runner services — generate with: openssl rand -hex 32)
ENCRYPTION_KEY=

# PostgreSQL (used by the bundled postgres container)
POSTGRES_PASSWORD=pulsarteam

# CORS (comma-separated origins). Explicit allow-list — '*' is REJECTED in
# production because the API uses credentials:true (the CORS spec forbids the
# combination, and accepting it would expose authenticated endpoints to any site).
CORS_ORIGINS=http://localhost:5173,http://localhost

# Google OAuth (optional — powers "Sign in with Google" AND the Gmail+Drive plugins)
# One OAuth client serves login + both plugins; the service is encoded in the
# OAuth state parameter.
# Create credentials at https://console.cloud.google.com/apis/credentials and
# enable the APIs you need (Gmail, Drive).
# In "Authorized redirect URIs", register BOTH paths the app uses (no env var
# needed — PulsarTeam derives them from each request):
#   https://your-domain.com/auth/google/callback        ← LOGIN (frontend route)
#   https://your-domain.com/api/google/oauth-redirect   ← PLUGINS (backend dispatcher)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth (optional — powers "Sign in with Microsoft" AND OneDrive/Outlook plugins)
# One Azure App registration serves login + every Microsoft Graph plugin; the
# service is encoded in the OAuth state parameter.
# Register an app at https://entra.microsoft.com → App registrations.
# Tenant ID: "common" for personal + work accounts, your tenant UUID for an
# org-only app.
# In "Redirect URIs", register BOTH paths the app uses (no env var needed):
#   https://your-domain.com/auth/microsoft/callback        ← LOGIN (frontend route)
#   https://your-domain.com/api/microsoft/oauth-redirect   ← PLUGINS (backend dispatcher)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Git identity for agent commits
GIT_USER_NAME=PulsarTeam
GIT_USER_EMAIL=agent@pulsarteam.local

# GitHub (optional — for cloning private repos + project activity feed)
# Token requires 'repo' scope for private repos, 'public_repo' for public only
GITHUB_TOKEN=
GITHUB_USER=

# Claude Code runner service (claudecode-service, started by default)
CLAUDE_CODE_OAUTH_TOKEN=
CLAUDE_MODEL=claude-opus-4-6
CLAUDE_MAX_TURNS=50
CODER_API_KEY=change-me-in-production
CODER_PUID=1000
CODER_PGID=1000

# GitHub OAuth (optional — powers "Sign in with GitHub" AND the per-agent GitHub plugin)
# One OAuth App serves login + the plugin; the path determines which handler.
# Create an OAuth App at https://github.com/settings/developers and register
# BOTH callback URLs (no env var needed — derived from each request):
#   https://your-domain.com/auth/github/callback        ← LOGIN (frontend route)
#   https://your-domain.com/api/github/oauth-redirect   ← PLUGIN (backend dispatcher)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Slack OAuth (optional — powers the Slack plugin)
# The redirect URI must be the backend dispatcher and must match the one
# registered in the Slack app settings:
#   https://your-domain.com/api/slack/oauth-redirect
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=

# ──────────────────────────────────────────────
# Office Documents + Local Folder desktop app
# ──────────────────────────────────────────────
# Office-engine MCP service (read/edit/generate/convert DOCX/XLSX/PPTX/PDF for
# any configured LLM). Defaults to the compose service name; override only if you
# run office-service elsewhere.
OFFICE_SERVICE_URL=http://office-service:8000
# Where the PulsarTeam desktop app installers are hosted. Surfaced by the in-app
# "Local Folder" connector when no desktop is connected. Leave empty until built.
DESKTOP_DOWNLOAD_URL=
