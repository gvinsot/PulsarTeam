# ──────────────────────────────────────────────
# PulsarTeam — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# Server
JWT_SECRET=change-me-to-a-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=swarm2026

# PostgreSQL (used by the bundled postgres container)
POSTGRES_PASSWORD=pulsarteam

# CORS (comma-separated origins). Explicit allow-list — '*' is REJECTED in
# production because the API uses credentials:true (the CORS spec forbids the
# combination, and accepting it would expose authenticated endpoints to any site).
CORS_ORIGINS=http://localhost:5173,http://localhost



# Google OAuth (optional — enables "Sign in with Google" button)
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Add the redirect URI to "Authorized redirect URIs" in the OAuth client:
#   https://your-domain.com/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/google/callback

# Microsoft / Live.com OAuth (optional — enables "Sign in with Microsoft" button)
# Register an app at https://entra.microsoft.com → App registrations
# Set Redirect URI to: https://your-domain.com/auth/microsoft/callback
# Under "Supported account types" choose "Personal Microsoft accounts only" for live.com
# or "Accounts in any organizational directory and personal Microsoft accounts" for both
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=https://your-domain.com/auth/microsoft/callback

# Git identity for agent commits
GIT_USER_NAME=PulsarTeam
GIT_USER_EMAIL=agent@pulsarteam.local

# GitHub (optional — for cloning private repos + project activity feed)
# Token requires 'repo' scope for private repos, 'public_repo' for public only
GITHUB_TOKEN=
GITHUB_USER=

# SSH keys path on the host (mounted read-only into containers)
SSH_KEYS_HOST_PATH=/home/youruser/.ssh

# Host code path (parent directory of PulsarTeam, mounted into runner-services)
HOST_CODE_PATH=/home/youruser

# Claude Code runner service (optional — enable with: docker compose --profile coder up -d)
CLAUDE_CODE_OAUTH_TOKEN=
CLAUDE_MODEL=claude-opus-4-6
CLAUDE_MAX_TURNS=50
CODER_API_KEY=change-me-in-production
CODER_PUID=1000
CODER_PGID=1000

# OneDrive integration (optional)
# Register an app at https://entra.microsoft.com → App registrations.
# Redirect URI must point to the frontend callback page, e.g.
#   https://your-domain.com/onedrive-callback.html  (prod)
#   http://localhost/onedrive-callback.html         (dev, frontend on :80)
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_REDIRECT_URI=
ONEDRIVE_TENANT_ID=

# Gmail integration (optional — per-agent OAuth)
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Enable the Gmail API at https://console.cloud.google.com/apis/library/gmail.googleapis.com
# Redirect URI must point to the frontend callback page, e.g.
#   https://your-domain.com/gmail-callback.html  (prod)
#   http://localhost/gmail-callback.html         (dev, frontend on :80)
#   http://localhost:5173/gmail-callback.html    (dev, Vite dev server)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=

# GitHub integration (optional — per-agent OAuth)
# Create an OAuth App at https://github.com/settings/developers
# Set Authorization callback URL to your domain + /github-callback.html
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=
