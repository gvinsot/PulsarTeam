{
  "name": "pulsarteam-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "PulsarTeam local companion app — share a local folder with your agents (files stay on your machine) and work on Office documents.",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "node --import tsx --test test/*.test.ts",
    "package": "node scripts/package.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "express": "^4.21.2",
    "http-proxy-middleware": "^3.0.3",
    "socket.io-client": "^4.8.1",
    "webview-nodejs": "^0.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
