{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "outDir": "node_modules/.tmp/tsconfig.node.tsbuildinfo.d",
    "strict": false,
    "noImplicitAny": false
  },
  "include": ["vite.config.ts", "postcss.config.ts", "tailwind.config.ts"]
}
